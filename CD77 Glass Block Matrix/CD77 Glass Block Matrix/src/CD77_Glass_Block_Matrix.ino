// Create the palette animation object (palettes are handled internally)
CD77_slowchangepalette paletteAnimation(leds, NUM_LEDS, BRIGHTNESS);

#include "Time_performance.h"

void setup() {
  delay(1000); // Power-up safety delay
    // Initialize FastLED
  FastLED.addLeds<LED_TYPE, LED_PIN, COLOR_ORDER>(leds, NUM_LEDS);
  FastLED.setBrightness(BRIGHTNESS);
  FastLED.setMaxPowerInVoltsAndMilliamps(5, 4000);
  set_max_power_indicator_LED(13);

  // Initialize time performance
  RestartPerformance();

}

// ===========================================
// Main Loop
// ===========================================
void loop() {
  // Update time code
  gTimeCode = millis() - gTimeCodeBase;
  //ropestuff stuff:
 offset = beat8(speed);
  // Run the time-coded performance
  // The multitasking CD77_slowchangepalette function
  // will handle smooth transitions without blocking
  Performance();
  
  // Other code can run here without interrupting animations!
}
